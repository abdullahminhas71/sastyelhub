<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SEELINGS Admin | Product Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        
        .glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        
        .preview-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 12px;
            display: none;
        }
        
        .preview-image.show {
            display: block;
        }
        
        .product-card {
            transition: all 0.3s ease;
        }
        
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        
        .drag-active {
            border-color: #000 !important;
            background: #f3f4f6 !important;
        }
        
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #1a1a1a;
            color: white;
            padding: 16px 24px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            z-index: 9999;
            transform: translateX(400px);
            transition: all 0.3s ease;
        }
        
        .toast.show {
            transform: translateX(0);
        }
        
        .tab-active {
            border-bottom: 2px solid #000;
            color: #000;
        }
        
        .size-btn {
            transition: all 0.2s;
        }
        
        .size-btn.selected {
            background: #000;
            color: #fff;
            border-color: #000;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">

    <!-- Navigation -->
    <nav class="fixed w-full z-50 glass border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-black text-white rounded-xl flex items-center justify-center font-bold text-lg">S</div>
                    <div>
                        <h1 class="font-bold text-lg">SEELINGS Admin</h1>
                        <p class="text-xs text-gray-500">Product Manager</p>
                    </div>
                </div>
                
                <div class="flex items-center gap-4">
                    <a href="index.html" target="_blank" class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-black transition flex items-center gap-2">
                        <i class="fas fa-external-link-alt"></i>
                        View Store
                    </a>
                    <button onclick="exportProducts()" class="px-4 py-2 bg-black text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition flex items-center gap-2">
                        <i class="fas fa-download"></i>
                        Export Code
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-24 pb-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Total Products</p>
                        <p class="text-3xl font-bold" id="total-products">0</p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600">
                        <i class="fas fa-box text-xl"></i>
                    </div>
                </div>
            </div>
            
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Women's Items</p>
                        <p class="text-3xl font-bold" id="women-count">0</p>
                    </div>
                    <div class="w-12 h-12 bg-pink-100 rounded-xl flex items-center justify-center text-pink-600">
                        <i class="fas fa-female text-xl"></i>
                    </div>
                </div>
            </div>
            
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">Men's Items</p>
                        <p class="text-3xl font-bold" id="men-count">0</p>
                    </div>
                    <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600">
                        <i class="fas fa-male text-xl"></i>
                    </div>
                </div>
            </div>
            
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm text-gray-500 mb-1">On Sale</p>
                        <p class="text-3xl font-bold" id="sale-count">0</p>
                    </div>
                    <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center text-red-600">
                        <i class="fas fa-tag text-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
            
            <!-- Left Side: Add Product Form -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 sticky top-24">
                    <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
                        <i class="fas fa-plus-circle text-green-600"></i>
                        Add New Product
                    </h2>
                    
                    <form id="product-form" onsubmit="handleSubmit(event)">
                        
                        <!-- Product Name -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Product Name *</label>
                            <input type="text" id="product-name" required
                                   class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-black focus:ring-2 focus:ring-black/5 transition"
                                   placeholder="e.g., Embroidered Lawn Suit">
                        </div>

                        <!-- Category -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Category *</label>
                            <select id="product-category" required
                                    class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-black focus:ring-2 focus:ring-black/5 transition">
                                <option value="">Select Category</option>
                                <option value="women">Women</option>
                                <option value="men">Men</option>
                                <option value="accessories">Accessories</option>
                                <option value="kids">Kids</option>
                            </select>
                        </div>

                        <!-- Price -->
                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Price *</label>
                                <input type="number" id="product-price" required min="0"
                                       class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-black focus:ring-2 focus:ring-black/5 transition"
                                       placeholder="2500">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Sale Price (Optional)</label>
                                <input type="number" id="product-sale-price" min="0"
                                       class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-black focus:ring-2 focus:ring-black/5 transition"
                                       placeholder="1999">
                            </div>
                        </div>

                        <!-- Image Upload -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Product Image *</label>
                            
                            <!-- Drag & Drop Zone -->
                            <div id="drop-zone" class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center cursor-pointer hover:border-gray-400 transition bg-gray-50"
                                 onclick="document.getElementById('file-input').click()"
                                 ondrop="handleDrop(event)" 
                                 ondragover="handleDragOver(event)"
                                 ondragleave="handleDragLeave(event)">
                                
                                <i class="fas fa-cloud-upload-alt text-3xl text-gray-400 mb-2"></i>
                                <p class="text-sm text-gray-600 mb-1">Click to upload or drag & drop</p>
                                <p class="text-xs text-gray-400">PNG, JPG up to 5MB</p>
                                
                                <input type="file" id="file-input" class="hidden" accept="image/*" onchange="handleFileSelect(event)">
                            </div>
                            
                            <!-- Image Preview -->
                            <img id="image-preview" class="preview-image mt-4">
                            
                            <!-- OR URL Input -->
                            <div class="mt-3">
                                <p class="text-xs text-gray-500 text-center mb-2">— OR —</p>
                                <input type="url" id="image-url" 
                                       class="w-full px-4 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:border-black"
                                       placeholder="Paste image URL here"
                                       onchange="previewFromURL()">
                            </div>
                        </div>

                        <!-- Sizes -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Available Sizes *</label>
                            <div class="flex flex-wrap gap-2" id="size-selector">
                                <button type="button" class="size-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium" onclick="toggleSize(this, 'XS')">XS</button>
                                <button type="button" class="size-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium" onclick="toggleSize(this, 'S')">S</button>
                                <button type="button" class="size-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium" onclick="toggleSize(this, 'M')">M</button>
                                <button type="button" class="size-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium" onclick="toggleSize(this, 'L')">L</button>
                                <button type="button" class="size-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium" onclick="toggleSize(this, 'XL')">XL</button>
                                <button type="button" class="size-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium" onclick="toggleSize(this, 'XXL')">XXL</button>
                                <button type="button" class="size-btn px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium" onclick="toggleSize(this, 'One Size')">One Size</button>
                            </div>
                            <input type="hidden" id="selected-sizes" required>
                        </div>

                        <!-- Colors -->
                        <div class="mb-4">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Colors (comma separated)</label>
                            <input type="text" id="product-colors"
                                   class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-black focus:ring-2 focus:ring-black/5 transition"
                                   placeholder="Red, Blue, Black, White">
                        </div>

                        <!-- Badge -->
                        <div class="mb-6">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Badge (Optional)</label>
                            <select id="product-badge"
                                    class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-black focus:ring-2 focus:ring-black/5 transition">
                                <option value="">No Badge</option>
                                <option value="New">New Arrival</option>
                                <option value="Sale">On Sale</option>
                                <option value="Bestseller">Bestseller</option>
                                <option value="Limited">Limited Edition</option>
                            </select>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="w-full py-4 bg-black text-white font-semibold rounded-xl hover:bg-gray-800 transition transform active:scale-95 flex items-center justify-center gap-2">
                            <i class="fas fa-plus"></i>
                            Add Product
                        </button>
                        
                        <button type="button" onclick="resetForm()" class="w-full mt-3 py-3 border border-gray-300 text-gray-700 font-medium rounded-xl hover:bg-gray-50 transition">
                            Reset Form
                        </button>
                    </form>
                </div>
            </div>

            <!-- Right Side: Product List -->
            <div class="lg:col-span-2">
                
                <!-- Tabs -->
                <div class="flex gap-6 border-b border-gray-200 mb-6 overflow-x-auto">
                    <button onclick="filterProducts('all')" class="tab-btn tab-active pb-3 font-medium text-sm whitespace-nowrap" data-tab="all">
                        All Products
                    </button>
                    <button onclick="filterProducts('women')" class="tab-btn pb-3 font-medium text-sm text-gray-500 hover:text-black whitespace-nowrap" data-tab="women">
                        Women
                    </button>
                    <button onclick="filterProducts('men')" class="tab-btn pb-3 font-medium text-sm text-gray-500 hover:text-black whitespace-nowrap" data-tab="men">
                        Men
                    </button>
                    <button onclick="filterProducts('accessories')" class="tab-btn pb-3 font-medium text-sm text-gray-500 hover:text-black whitespace-nowrap" data-tab="accessories">
                        Accessories
                    </button>
                    <button onclick="filterProducts('kids')" class="tab-btn pb-3 font-medium text-sm text-gray-500 hover:text-black whitespace-nowrap" data-tab="kids">
                        Kids
                    </button>
                </div>

                <!-- Search & Actions -->
                <div class="flex gap-4 mb-6">
                    <div class="flex-1 relative">
                        <i class="fas fa-search absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input type="text" id="search-products" placeholder="Search products..."
                               class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:border-black"
                               onkeyup="searchProducts()">
                    </div>
                    <button onclick="clearAllProducts()" class="px-6 py-3 border border-red-300 text-red-600 rounded-xl hover:bg-red-50 transition font-medium">
                        <i class="fas fa-trash-alt mr-2"></i>
                        Clear All
                    </button>
                </div>

                <!-- Products Grid -->
                <div id="products-list" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Products will be rendered here -->
                </div>

                <!-- Empty State -->
                <div id="empty-state" class="hidden text-center py-20">
                    <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-box-open text-4xl text-gray-400"></i>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 mb-2">No products yet</h3>
                    <p class="text-gray-500">Add your first product using the form</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Edit Modal -->
    <div id="edit-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
        <div class="bg-white rounded-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto p-6 slide-in">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold">Edit Product</h3>
                <button onclick="closeEditModal()" class="w-8 h-8 rounded-full hover:bg-gray-100 flex items-center justify-center">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form id="edit-form" onsubmit="handleEditSubmit(event)">
                <input type="hidden" id="edit-id">
                <!-- Same fields as add form -->
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Product Name</label>
                        <input type="text" id="edit-name" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-black outline-none">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-1">Price</label>
                            <input type="number" id="edit-price" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-black outline-none">
            
